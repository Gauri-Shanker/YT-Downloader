{
  "name": "yt-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "type": "commonjs",
  "author": "YT Downloader",
  "description": "YouTube Audio/Video Downloader Desktop App",
  "scripts": {
    "start": "electron .",
    "dev": "cd frontend && npm run build && cd .. && electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "electron-builder --win",
    "build": "npm run build:frontend && npm run build:electron",
    "pack": "electron-builder --dir",
    "package": "npx @electron/packager . \"YT Downloader\" --platform=win32 --arch=x64 --out=dist-packaged --icon=icon.ico --overwrite --ignore=\"backend(?!/dist)\" --ignore=node_modules",
    "convert-icon": "node convert-icon.js"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.ytdownloader.app",
    "productName": "YT Downloader",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/app.exe",
        "to": "app.exe"
      },
      {
        "from": "icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "cookies.txt",
        "to": "cookies.txt"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}